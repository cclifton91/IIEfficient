---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Navigation.astro";
import Footer from "../components/Footer.astro"; 
import Intro from "../components/Intro.astro";
import Projects from "../components/Projects.astro";
import InstaFeed from "../components/InstaFeed.astro";
import Contact from "../components/Contact.astro";
import settings from "../data/settings.json";

import cookies from '../assets/Cookieslogo.png';
import hawks from '../assets/HawksLogo.png';
import ub from '../assets/UBlogo.png';
import trival from '../assets/TriValLogo.png';
import iu from '../assets/IUlogo.png';
import cs from '../assets/Clutchsportsmedia.png';


//Props
const seo = {
  title: "II Efficient Media",
  description: "Specialized Digital Content Creation for Social Media",
};
const navLinks = [
  { href: "#home", text: "Home" },
  { href: "#about", text: "About" },
  { href: "#feed", text: "Content" },
  { href: "#projects", text: "Projects" },
];

---

<Layout {seo}>
  <Nav navLinks={navLinks} logo="TriangleLogo" slot="header"/>
  <Intro
    title = {settings.title}
    videoSrc= {settings.videoSrc}
    logos = {settings.logos}
    aboutText = {settings.aboutText}
  />
  <Projects />
  <InstaFeed contentFeed = {settings.contentFeed} />
  <Contact 
    address = {settings.address}
    phone = {settings.phone}
    email = {settings.email}
  >
  <Footer slot="footer"/>
</Layout>
