---
import { Image } from "astro:assets";
import Layout from "../layouts/Base.astro";
import Nav from "../components/Navigation.astro";
import Footer from "../components/Footer.astro"; 
import Intro from "../components/Intro.astro";
import Projects from "../components/Projects.astro";

import cookies from '../assets/Cookieslogo.png';
import hawks from '../assets/HawksLogo.png';
import ub from '../assets/UBlogo.png';
import trival from '../assets/TriValLogo.png';
import iu from '../assets/IUlogo.png';
import cs from '../assets/Clutchsportsmedia.png';

const logos = [
  { src: cookies, alt: "Cookies Logo" },
  { src: hawks, alt: "Hawks Logo" },
  { src: ub, alt: "UB Logo" },
  { src: trival, alt: "TriVal Logo" },
  { src: iu, alt: "IU Logo" },
  { src: cs, alt: "Clutch Sports Media Logo" },

];

//Props
const seo = {
  title: "II Efficient Media",
  description: "Specialized Digital Content Creation for Social Media",
};
const navLinks = [
  { href: "#home", text: "Home" },
  { href: "#about", text: "About" },
  { href: "#projects", text: "Projects" },
];
---

<Layout {seo}>
  <Nav navLinks={navLinks} logo="TriangleLogo" slot="header"/>
  <Intro
    videoSrc="/assets/IIEfficientIntro.mp4"
    mainTitle="II EFFICIENT MEDIA"
    subTitle="CAPTURING COMPELLING STORIES"
    aboutTitle="WE HELP GROW BUSINESSES"
    aboutText1="II Efficient Media - where storytelling meets creativity. Based in Illinois, we are a vibrant creative agency specializing in crafting high-quality, visually stunning content for athletes, colleges, and businesses across the state."
    aboutText2="With over three years of professional experience, our team is dedicated to capturing the heart of athletics and business storytelling. From showcasing the determination of a game to highlighting the passion of an athlete or elevating a brand's message, every project is an opportunity to create something extraordinary."
    logos={logos}
  />
  <Projects />
  <Footer slot="footer"/>
</Layout>
