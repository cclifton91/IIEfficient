---
import { Icon } from 'astro-icon/components';
import settings from '../data/settings.js';

---

<footer class="footer-v3 py-8 lg:py-12 bg-accent" slot="footer">
  <div class="footer-v3__container w-[calc(100%_-_2.5rem)] lg:w-[calc(100%_-_4rem)] mx-auto max-w-7xl">
    <div class="footer-v3__logo">
      <a href="#home">
        <Icon name="TriangleLogo" class="footer-v3__logo" />
      </a>
    </div>

    <nav class="footer-v3__nav">
      <ul class="footer-v3__nav-list">
        <!--<li class="footer-v3__nav-item"><a href="#0">Pricing</a></li>
        <li class="footer-v3__nav-item"><a href="#0">Documentation</a></li>
        <li class="footer-v3__nav-item"><a href="#0">Help center</a></li>
        <li class="footer-v3__nav-item"><a href="#0">Company</a></li>-->
      </ul>
    </nav>

    <div class="footer-v3__socials">
      <a href={settings.instagramURL}>
          <Icon name="instagram24" class="icon inline-block text-inherit fill-current leading-none shrink-0" />
      </a>

      <a href={settings.facebookURL}>
        <Icon name="facebook24" class="icon inline-block text-inherit fill-current leading-none shrink-0" />
      </a>

      <a href={settings.tikTokURL}>
        <Icon name="tiktok24" class="icon inline-block text-inherit fill-current leading-none shrink-0" />
      </a>
    </div>
  </div>
</footer>

<!--Style---------------------------------------------------------------------------------------------------------------->
<style>
  .footer-v3 {
    position: relative;
    z-index: 1;
  }

  .footer-v3__logo a, .footer-v3__logo svg, .footer-v3__logo img {
    width: 104px;
    height: 30px;
    display: block;
  }

  .footer-v3__nav {
    @apply my-8 lg:my-12 mx-0;
  }

  .footer-v3__nav-item {
    @apply mt-3 lg:mt-5;
  }
  .footer-v3__nav-item a {
    @apply text-gray-700;
    font-size: 1.25em;
  }
  .footer-v3__nav-item a:hover {
    @apply text-primary;
  }

  .footer-v3__socials {
    display: flex;
    align-items: center;
  }
  .footer-v3__socials a {
    text-decoration: none;
    display: inline-block;
    @apply my-0 ml-0 mr-2 lg:mr-3;
    @apply text-gray-700;
  }
  .footer-v3__socials a:hover {
    @apply text-primary;
  }
  .footer-v3__socials a .icon {
    display: block;
    width: 1.25em;
    height: 1.25em;
  }

  @supports (display: grid) {
    @media (min-width: 64rem) {
      .footer-v3__container {
        display: grid;
        grid-template-columns: 130px 1fr 130px;
      }

      .footer-v3__nav {
        margin: 0;
      }

      .footer-v3__nav-list {
        display: flex;
        height: 100%;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
      }

      .footer-v3__nav-item {
        @apply py-0 px-2 lg:px-3;
        margin: 0;
        position: relative;
      }
      .footer-v3__nav-item a {
        font-size: 0.875em;
      }
      .footer-v3__nav-item::after {
        content: "";
        display: inline-block;
        position: absolute;
        height: 0.8em;
        width: 1px;
        right: 0;
        top: calc(50% - 0.4em);
        @apply bg-gray-300;
      }
      .footer-v3__nav-item:first-child {
        padding-left: 0;
      }
      .footer-v3__nav-item:last-child {
        padding-right: 0;
      }
      .footer-v3__nav-item:last-child::after {
        display: none;
      }

      .footer-v3__socials a {
        @apply my-0 mr-0 ml-2 lg:ml-3;
      }
      .footer-v3__socials a .icon {
        width: 1em;
        height: 1em;
      }
    }
  }
</style>